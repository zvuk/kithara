(
    schema: "kithara.module",
    version: 1,
    id: "gallery-module-global-bar",
    title: Some("Глобальная панель"),
    chip: Some("BAR"),
    chrome: Full,
    footer: Some(Model(id: "gallery.footer.global_bar")),
    root: Column(
        children: [
            Slot(
                id: "content",
                size: (w: Fill, h: Fill),
                default: [
                    Include(id: "global-bar", source: "global-bar.kmodule.ron"),
                ],
            ),
        ],
    ),
)

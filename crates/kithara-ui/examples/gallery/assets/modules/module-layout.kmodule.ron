(
    schema: "kithara.module",
    version: 1,
    id: "gallery-module-layout",
    title: Some("Раскладка"),
    chip: Some("LAY"),
    chrome: Full,
    footer: Some(Model(id: "gallery.footer.layout")),
    root: Column(
        children: [
            Slot(
                id: "content",
                size: (w: Fill, h: Fill),
                default: [
                    Include(id: "layout", source: "library.kmodule.ron"),
                ],
            ),
        ],
    ),
)

(
    schema: "kithara.module",
    version: 1,
    id: "gallery-faders-tab",
    root: Column(
        gap: Some(18.0),
        pad: Some(14.0),
        children: [
            Control(id: "text-title", kind: "text", props: { "style": Text("section") }, read: Model(id: "gallery.label.text")),
            Control(
                id: "track-title",
                kind: "text",
                props: { "style": Text("track-title") },
                read: Model(id: "mock.track.title"),
            ),
            Control(id: "artist", kind: "text", read: Model(id: "mock.track.artist")),
            Control(id: "fader-title", kind: "text", props: { "style": Text("section") }, read: Model(id: "gallery.label.faders")),
            Control(
                id: "default",
                kind: "fader.horizontal",
                size: (w: Fixed(220.0), h: Fixed(34.0)),
                read: Model(id: "mock.volume"),
            ),
            Control(
                id: "volume",
                kind: "fader.horizontal",
                size: (w: Fixed(120.0), h: Fixed(34.0)),
                props: { "style": Text("volume") },
                read: Model(id: "mock.volume"),
            ),
            Control(id: "scalar-title", kind: "text", props: { "style": Text("section") }, read: Model(id: "gallery.label.scalar")),
            Control(
                id: "scalar",
                kind: "telemetry.scalar",
                size: (w: Fixed(64.0), h: Fixed(18.0)),
                props: { "format": Text("percent") },
                read: Model(id: "mock.volume"),
            ),
        ],
    ),
)

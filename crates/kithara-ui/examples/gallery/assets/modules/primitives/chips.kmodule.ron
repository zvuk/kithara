(
    schema: "kithara.module",
    version: 1,
    id: "gallery-chips",
    root: Column(
        gap: Some(8.0),
        children: [
            Control(id: "title", kind: "text", props: { "style": Text("section") }, read: Model(id: "gallery.label.chips")),
            Row(
                gap: Some(8.0),
                children: [
                    Control(
                        id: "active",
                        kind: "chip",
                        size: (w: Fixed(20.0), h: Fixed(16.0)),
                        props: { "label": Text("A") },
                        read: Model(id: "mock.chip.active"),
                    ),
                    Control(
                        id: "inactive",
                        kind: "chip",
                        size: (w: Fixed(28.0), h: Fixed(16.0)),
                        props: { "label": Text("FX1") },
                        read: Model(id: "mock.chip.inactive"),
                    ),
                ],
            ),
        ],
    ),
)

(
    schema: "kithara.module",
    version: 1,
    id: "gallery-module-deck",
    root: Column(
        children: [
            Include(id: "selector", source: "module-tabs.kmodule.ron"),
            Slot(
                id: "content",
                size: (w: Fill, h: Fill),
                default: [
                    Include(
                        id: "deck",
                        source: "deck.kmodule.ron",
                        with: { "deck": "a" },
                    ),
                ],
            ),
        ],
    ),
)

                (node: Module(instance: "deck-c", source: "modules/deck.kmodule.ron", with: { "deck": "c" })),
            ])),
            (weight: 1.0, node: Split(axis: Vertical, children: [
                (node: Module(instance: "deck-b", source: "modules/deck.kmodule.ron", with: { "deck": "b" })),
                (node: Module(instance: "deck-d", source: "modules/deck.kmodule.ron", with: { "deck": "d" })),
            ])),
        ],
    ),
)

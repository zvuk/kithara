(
    schema: "kithara.module",
    version: 1,
    id: "deck-transport",
    parameters: ["deck"],
    root: Row(
        size: (w: Fill, h: Fixed(30.0)),
        children: [
            Button(
                id: "cue",
                size: (w: Fixed(58.0), h: Fixed(30.0)),
                label: "CUE",
                style: Transport,
                write: Command(id: "deck.transport.set_cue", with: { "deck": "$deck" }),
            ),
            Button(
                id: "play",
                size: (w: Fixed(72.0), h: Fixed(30.0)),
                label: "PLAY",
                icon: Some(Play),
                style: Transport,
                read: Telemetry(id: "deck.playback.playing", with: { "deck": "$deck" }),
                write: Command(id: "deck.transport.toggle_play", with: { "deck": "$deck" }),
                adaptive: (priority: Required),
            ),
            Button(
                id: "sync",
                size: (w: Fixed(58.0), h: Fixed(30.0)),
                label: "SYNC",
                style: Transport,
                read: Telemetry(id: "deck.playback.synced", with: { "deck": "$deck" }),
                write: Command(id: "deck.transport.toggle_sync", with: { "deck": "$deck" }),
            ),
            Button(
                id: "reverse",
                size: (w: Fixed(48.0), h: Fixed(30.0)),
                label: "",
                icon: Some(PlayReverse),
                style: Transport,
                read: Telemetry(id: "deck.playback.reverse", with: { "deck": "$deck" }),
                write: Command(id: "deck.transport.toggle_reverse", with: { "deck": "$deck" }),
            ),
            Button(
                id: "loop",
                size: (w: Fixed(74.0), h: Fixed(30.0)),
                label: "LOOP 4",
                style: Transport,
                read: Telemetry(id: "deck.playback.looping", with: { "deck": "$deck" }),
                write: Command(id: "deck.transport.toggle_loop", with: { "deck": "$deck" }),
            ),
            Button(
                id: "jump-back",
                size: (w: Fixed(52.0), h: Fixed(30.0)),
                label: "",
                icon: Some(Rewind),
                style: Transport,
                write: Command(id: "deck.transport.jump_back", with: { "deck": "$deck" }),
            ),
            Button(
                id: "jump-forward",
                size: (w: Fixed(52.0), h: Fixed(30.0)),
                label: "",
                icon: Some(FastForward),
                style: Transport,
                write: Command(id: "deck.transport.jump_forward", with: { "deck": "$deck" }),
            ),
            Spacer(id: "spacer", size: (w: Fill, h: Fixed(30.0))),
            Button(
                id: "zoom-out",
                size: (w: Fixed(36.0), h: Fixed(30.0)),
                label: "",
                icon: Some(ZoomOut),
                style: Transport,
                write: Command(id: "deck.view.zoom_out", with: { "deck": "$deck" }),
            ),
            Button(
                id: "zoom-in",
                size: (w: Fixed(36.0), h: Fixed(30.0)),
                label: "",
                icon: Some(ZoomIn),
                style: Transport,
                write: Command(id: "deck.view.zoom_in", with: { "deck": "$deck" }),
            ),
            Select(
                id: "stream",
                size: (w: Fixed(178.0), h: Fixed(30.0)),
                label: "HLS AUTO·320 BUF 18S",
            ),
            Readout(
                id: "tempo",
                size: (w: Fixed(154.0), h: Fixed(30.0)),
                label: Some("TEMPO"),
                tone: Accent,
                framed: true,
                read: Telemetry(id: "deck.playback.tempo", with: { "deck": "$deck" }),
            ),
        ],
    ),
)

(
    schema: "kithara.module",
    version: 1,
    id: "global-bar",
    root: Row(
        children: [
            Brand(id: "brand"),
            PresetSelector(id: "presets"),
            Spacer(id: "spacer"),
            Fader(
                id: "volume",
                size: (w: Fixed(152.0), h: Fixed(34.0)),
                style: VolumeCompact,
                read: Parameter(id: "player.output.volume"),
                write: Parameter(id: "player.output.volume"),
            ),
            SettingsButton(id: "settings"),
        ],
    ),
)

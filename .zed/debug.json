[
  {
    "label": "kithara-app: auto",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "cargo",
      "args": ["build", "-p", "kithara-app", "--bin", "kithara"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/kithara",
    "args": ["--mode", "auto"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {
      "RUST_LOG": "trace",
      "RUST_BACKTRACE": "1",
    },
    "sourceLanguages": ["rust"],
  },
  {
    "label": "kithara-app: tui",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "cargo",
      "args": ["build", "-p", "kithara-app", "--bin", "kithara"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/kithara",
    "args": ["--mode", "tui"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {
      "RUST_LOG": "trace",
      "RUST_BACKTRACE": "1",
    },
    "sourceLanguages": ["rust"],
  },
  {
    "label": "kithara-app: gui",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "cargo",
      "args": ["build", "-p", "kithara-app", "--bin", "kithara"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/kithara",
    "args": ["--mode", "gui"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {
      "RUST_LOG": "kithara_audio=trace,kithara_hls=trace,kithara_stream=trace",
      "RUST_BACKTRACE": "1",
    },
    "sourceLanguages": ["rust"],
  },

[
  {
    "label": "kithara-app: auto",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "cargo",
      "args": ["build", "-p", "kithara-app", "--bin", "kithara"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/kithara",
    "args": ["--mode", "auto"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {
      "RUST_LOG": "debug",
      "RUST_BACKTRACE": "1",
    },
    "sourceLanguages": ["rust"],
  },
  {
    "label": "kithara-app: tui",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "cargo",
      "args": ["build", "-p", "kithara-app", "--bin", "kithara"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/kithara",
    "args": ["--mode", "tui"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {
      "RUST_LOG": "debug",
      "RUST_BACKTRACE": "1",
    },
    "sourceLanguages": ["rust"],
  },
  {
    "label": "kithara-app: gui",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "cargo",
      "args": ["build", "-p", "kithara-app", "--bin", "kithara"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/kithara",
    "args": ["--mode", "gui"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "env": {
      "RUST_LOG": "kithara_audio=debug,kithara_decode=info,kithara_hls=debug,kithara_assets=debug,kithara_stream=debug,kithara_queue=debug,kithara_play=info",
      "RUST_BACKTRACE": "1",
      "KITHARA_LOG_FILE": "$ZED_WORKTREE_ROOT/app.log",
    },
    "sourceLanguages": ["rust"],
  },
  {
    "label": "iOS demo",
    "adapter": "CodeLLDB",
    "request": "attach",
    "build": {
      "command": "cargo",
      "args": ["run", "-p", "xtask", "--", "apple", "run", "--debug"],
    },
    "program": "KitharaDemo",
    "sourceLanguages": ["swift"],
  },
]

#!/usr/bin/env bash
# Git pre-commit entrypoint.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if ! command -v lefthook >/dev/null 2>&1; then
    echo "pre-commit: lefthook is required. Install it: https://github.com/evilmartians/lefthook#install"
    exit 1
fi

exec lefthook run pre-commit

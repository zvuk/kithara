{
  "goog:chromeOptions": {
    "args": [
      "--headless=new",
      "--disable-background-networking",
      "--disable-extensions",
      "--no-sandbox",
      "--disable-gpu",
      "--disable-dev-shm-usage",
      "--autoplay-policy=no-user-gesture-required",
      "--enable-features=SharedArrayBuffer",
      "--js-flags=--experimental-wasm-threads"
    ],
    "w3c": false
  }
}